# Copy to .env for local dev.  All vars are prefixed STREAMVA_.

# Storage
STREAMVA_DATA_DIR=./data

# Libraries: either point at a YAML config...
# STREAMVA_CONFIG=../streamva.yaml
# ...or use a single-root fallback:
# STREAMVA_COURSES_DIR=D:/udemy-downloads

# Scanning
STREAMVA_SCAN_ON_START=true
STREAMVA_SECTION_MAX_DEPTH=2

# Media
STREAMVA_FFMPEG=auto
STREAMVA_TRANSCODE=on-demand

# Auth (single shared credential)
STREAMVA_AUTH=basic
STREAMVA_AUTH_USER=admin
STREAMVA_AUTH_PASS=change-me

# Dev
STREAMVA_DEV_CORS=true
